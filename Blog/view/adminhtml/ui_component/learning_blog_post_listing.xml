<?xml version="1.0"?>
<listing name="learning_blog_post_listing"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">
                learning_blog_post_listing.learning_blog_post_listing_data_source
            </item>
            <item name="deps" xsi:type="string">
                learning_blog_post_listing.learning_blog_post_listing_data_source
            </item>
        </item>
        <item name="spinner" xsi:type="string">columns</item>
    </argument>

    <dataSource name="learning_blog_post_listing_data_source">
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">
                Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider
            </argument>
            <argument name="name" xsi:type="string">
                learning_blog_post_listing_data_source
            </argument>
            <argument name="primaryFieldName" xsi:type="string">post_id</argument>
            <argument name="requestFieldName" xsi:type="string">id</argument>

            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/grid/provider</item>
                    <item name="update_url" xsi:type="url" path="mui/index/render"/>
                    <item name="storageConfig" xsi:type="array">
                        <item name="indexField" xsi:type="string">post_id</item>
                    </item>
                </item>
            </argument>
        </argument>
    </dataSource>

    <listingToolbar name="listing_top">
        <buttons>
            <button name="add">
                <settings>
                    <label translate="true">Add New Post</label>
                    <class>primary</class>
                    <url path="blog/post/edit"/>
                </settings>
            </button>
        </buttons>

        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="columns">

        <!-- Checkbox column -->
        <selectionsColumn name="ids">
            <settings>
                <indexField>post_id</indexField>
            </settings>
        </selectionsColumn>

        <column name="post_id">
            <settings>
                <filter>textRange</filter>
                <sorting>asc</sorting>
                <label>ID</label>
            </settings>
        </column>

        <column name="name">
            <settings>
                <filter>text</filter>
                <label>Title</label>
            </settings>
        </column>

        <column name="url_key">
            <settings>
                <filter>text</filter>
                <label>URL Key</label>
            </settings>
        </column>

        <column name="description">
            <settings>
                <filter>text</filter>
                <label>Description</label>
            </settings>
        </column>

        <!-- <column name="updated_at" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label>Updated At</label>
            </settings>
        </column> -->

        <!-- <actionsColumn name="actions" class="Magento\Ui\Component\Listing\Columns\Column">
            <settings>
                <indexField>post_id</indexField>
            </settings>
        </actionsColumn> -->

    </columns>

</listing>
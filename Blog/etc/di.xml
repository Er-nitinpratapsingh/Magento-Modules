<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../lib/internal/Magento/Framework/ObjectManager/etc/config.xsd">

    <!-- Repository Preference -->
    <!-- <preference for="Learning\Blog\Api\PostRepositoryInterface"
                type="Learning\Blog\Model\PostRepository"/> -->

    <!-- UI Grid Collection Mapping (VERY IMPORTANT) -->
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="learning_blog_post_listing_data_source" xsi:type="string">
                    Learning\Blog\Model\ResourceModel\Post\Grid\CollectionVirtual
                </item>
            </argument>
        </arguments>
    </type>

    <virtualType name="Learning\Blog\Model\ResourceModel\Post\Grid\CollectionVirtual" type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">learning_blog_post</argument>
            <argument name="resourceModel" xsi:type="string">Learning\Blog\Model\ResourceModel\Post</argument>
        </arguments>
    </virtualType>

</config>
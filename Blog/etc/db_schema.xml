<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="learning_blog_post" engine="innodb" resource="default" comment="Blog Posts">
        <column xsi:type="int" name="post_id" identity="true" unsigned="true" nullable="false"/>
        <column xsi:type="varchar" name="name" length="255" nullable="false"/>
        <column xsi:type="varchar" name="url_key" length="255" nullable="false"/>
        <column xsi:type="text" name="description" nullable="false"/>
        <column xsi:type="timestamp" name="created_at" default="CURRENT_TIMESTAMP"/>
        <column xsi:type="timestamp" name="updated_at" nullable="true" on_update="true"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="post_id"/>
        </constraint>
    </table>

</schema>